# Core
APP_ENV=development
DEBUG=false
EXPOSE_DEBUG_OTPS=true
OTP_TTL_MINUTES=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_REQUEST_OTP_LIMIT=5
AUTH_VERIFY_OTP_LIMIT=10
ADMIN_LOGIN_LIMIT=5
GEMINI_API_KEY=your_real_gemini_api_key
GEMINI_API_KEY2=your_second_gemini_api_key_for_voice_agent
GEMINI_MODEL=gemini-2.5-flash-lite
PDF_PATH=./backend/data/portfolio.pdf
JWT_SECRET_KEY=replace_with_long_random_secret
JWT_ALGORITHM=HS256
FRONTEND_ORIGIN=http://127.0.0.1:5500
CORS_ALLOW_ORIGINS=http://127.0.0.1:5500,http://localhost:3000

# Google integrations
GOOGLE_SERVICE_ACCOUNT_JSON=./backend/credentials/service_account.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheet_id
GOOGLE_CALENDAR_ID=your_calendar_id_or_email
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata
GOOGLE_CALENDAR_IMPERSONATE_USER=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_sender_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_sender_email@gmail.com

# Meeting fallback
DEFAULT_MEET_LINK=https://meet.google.com/your-default-link

# ImageKit
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_URL=https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_RESUME_FOLDER=/resumes
UPLOADED_RESUME_DIR=./backend/data/uploads
PUBLIC_BACKEND_URL=https://your-public-backend-url.example.com
VOBIZ_AUTH_ID=your_vobiz_auth_id
VOBIZ_AUTH_TOKEN=your_vobiz_auth_token
VOBIZ_WEBHOOK_SECRET=replace_with_random_secret
VOBIZ_CALL_DELAY_SECONDS=30
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_agent_resume

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password
